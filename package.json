{
  "name": "reflux-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Reflux — a Structured Yield OS for Sui (DeepBook Predict track, Sui Overflow 2026)",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint lib keeper/src sim/src --ext .ts && pnpm --filter app lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "move:build": "cd contracts && sui move build",
    "move:test": "cd contracts && sui move test",
    "sim": "pnpm --filter @reflux/sim start"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
