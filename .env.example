# ============================================================================
# Reflux environment — copy to .env.local (app) / .env (keeper, sim)
# Every variable consumed in code is declared here AND in
# lib/constants.ts#EnvSchema — keep both current together.
# Secrets (KEEPER_PRIVATE_KEY etc.) must NEVER be committed.
# ============================================================================

# --- Network ----------------------------------------------------------------
NEXT_PUBLIC_SUI_NETWORK=testnet

# --- Reflux deployment --------------------------------------------------------
# Package: use the UPGRADED address for all function calls. Coin types
# (RFUSD_TYPE, RFBTC_TYPE) and event types stay pinned to the ORIGINAL
# package per Sui's upgrade rules — see README "Deployed object IDs".
NEXT_PUBLIC_PACKAGE_ID=0x1a2b48289a2f018c2cdb18f330e36a3c1c150abbfca3cae5864931a3bac26967
NEXT_PUBLIC_VAULT_ID=0xbfc2a572cfa870e5ac3892890bddd49a9a0fc8ba72835164fde9b7f7fb186075
NEXT_PUBLIC_RFUSD_TYPE=0xee23c4aecc3ab750c2c62ca5861b4fc517f577b0f219d80fa25a42d838a09bea::share_token::SHARE_TOKEN
NEXT_PUBLIC_DEPOSIT_ROUTER_ID=0x436a992dd8be862499912829a71e1c4d5bdebf4c5033889e134635c884da9b2f
NEXT_PUBLIC_ALLOCATOR_ID=0x749fe68f56a41d7464e060b9d2d2480d3b633d7cb4fcaf9a6355e1e72f6f0658
NEXT_PUBLIC_IB_CREDIT_STATE_ID=0x65967b330149e5b8bce367130b25694fd57bf8e78c7a98e3b7f3a1c18d6f7261

# rfBTC — Reflux's own testnet BTC bridge coin (faucet-mintable; stands in
# for DeepBook's dbtc until that package is live on this testnet branch).
NEXT_PUBLIC_RFBTC_TYPE=0xee23c4aecc3ab750c2c62ca5861b4fc517f577b0f219d80fa25a42d838a09bea::rfbtc::RFBTC
NEXT_PUBLIC_RFBTC_TREASURY_ID=0x7aea4304538af559babade03e014b172d760fde1eaa6e44a7c122aac7cb5da44

# Internal spot router (USDC<->dUSDC treasury, SUI<->dUSDC and rfBTC<->dUSDC
# CPAMM pools) — resolves DR-1 from CLAUDE.md/INTEGRATION_NOTES.md.
NEXT_PUBLIC_SPOT_ROUTER_CONFIG_ID=0x8265f2bd6599c789fcac1ceefbd8564364bebde1b960d0e639c000323edecf56

# --- External protocols ------------------------------------------------------
# DeepBook Predict (branch predict-testnet-4-16) — immutable once published.
NEXT_PUBLIC_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
NEXT_PUBLIC_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
NEXT_PUBLIC_DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
NEXT_PUBLIC_PREDICT_SERVER=https://predict-server.testnet.mystenlabs.com
# Keeper's PredictManager object ID (created once via buildPredictCreateManagerTx)
KEEPER_PREDICT_MANAGER_ID=

# DeepBook Margin (Tier 2, leverage.move is interface-staged — see README)
NEXT_PUBLIC_MARGIN_PACKAGE_ID=

# --- zkLogin auth (Enoki) -----------------------------------------------------
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- LSDs / LSPs (Tier 2 — staking_adapter.move / lsd_adapter.move) ----------
NEXT_PUBLIC_VSUI_TYPE=
NEXT_PUBLIC_VOLO_STAKING_POOL=
NEXT_PUBLIC_AFTERMATH_STAKING_POOL=
NEXT_PUBLIC_HAEDAL_STAKING_POOL=

# --- Canonical BTC (Tier 3 — replaces rfBTC 1:1 once these exist) -----------
NEXT_PUBLIC_XBTC_TYPE=
NEXT_PUBLIC_SBTC_TYPE=
NEXT_PUBLIC_DBTC_TYPE=

# --- Pyth price feeds (SUI/USD, BTC/USD — used for LTV + FX tracking) --------
NEXT_PUBLIC_PYTH_SUI_PRICE_ID=
NEXT_PUBLIC_PYTH_BTC_PRICE_ID=
NEXT_PUBLIC_PYTH_BTC_PRICE_INFO_OBJECT_ID=

# --- Keeper secrets (server-side only, never NEXT_PUBLIC) --------------------
KEEPER_PRIVATE_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
