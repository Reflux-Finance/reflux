# ============================================================================
# Reflux environment — copy to .env.local (app) / .env (keeper, sim)
# Every variable consumed in code is declared here. Keep this file current.
# Secrets (KEEPER_PRIVATE_KEY etc.) must NEVER be committed.
# ============================================================================

# --- Network ----------------------------------------------------------------
NEXT_PUBLIC_SUI_NETWORK=testnet

# --- Reflux deployment (record after `sui client publish` in contracts/) ----
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_VAULT_ID=
NEXT_PUBLIC_RFUSD_TYPE=
NEXT_PUBLIC_DEPOSIT_ROUTER_ID=
NEXT_PUBLIC_ALLOCATOR_ID=
NEXT_PUBLIC_IB_CREDIT_STATE_ID=

# --- External protocols ------------------------------------------------------
# DeepBook Predict (branch predict-testnet-4-16) + Margin packages on testnet
NEXT_PUBLIC_PREDICT_PACKAGE_ID=
NEXT_PUBLIC_MARGIN_PACKAGE_ID=
NEXT_PUBLIC_PREDICT_SERVER=https://predict-server.testnet.mystenlabs.com
# USDC <-> dUSDC conversion venue (pending OPEN QUESTION 1 — see docs/INTEGRATION_NOTES.md)
NEXT_PUBLIC_USDC_DUSDC_POOL=

# --- LSDs / LSPs --------------------------------------------------------------
NEXT_PUBLIC_VSUI_TYPE=
NEXT_PUBLIC_VOLO_STAKING_POOL=
NEXT_PUBLIC_AFTERMATH_STAKING_POOL=
NEXT_PUBLIC_HAEDAL_STAKING_POOL=

# --- Pyth price feeds (SUI/USD, BTC/USD — used for LTV + FX tracking) --------
NEXT_PUBLIC_PYTH_SUI_PRICE_ID=
NEXT_PUBLIC_PYTH_BTC_PRICE_ID=

# --- Keeper secrets (server-side only, never NEXT_PUBLIC) --------------------
KEEPER_PRIVATE_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
